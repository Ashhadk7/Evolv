PROJECT_NAME="Evolv API"
ENVIRONMENT=local
DEBUG=true
API_V1_STR=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SIGNUP_OTP_EXPIRE_MINUTES=5
SIGNUP_OTP_RETURN_DEBUG=false
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_VERIFY_SERVICE_SID=YOUR_TWILIO_VERIFY_SERVICE_SID
TWILIO_VERIFY_CHANNEL=sms
TWILIO_TIMEOUT_SECONDS=20
EMAIL_FROM_EMAIL=YOUR_GMAIL_ADDRESS
EMAIL_FROM_NAME="Evolv AI"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=YOUR_GMAIL_ADDRESS
SMTP_PASSWORD=YOUR_GOOGLE_APP_PASSWORD
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=20
SECRET_KEY=YOUR_LONG_RANDOM_SECRET
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
GOOGLE_CALENDAR_CLIENT_ID=YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID
GOOGLE_CALENDAR_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_WEB_CLIENT_SECRET
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/v1/calendar/google/callback
GOOGLE_CALENDAR_FRONTEND_RETURN_URL=http://localhost:3000
AI_TIMEOUT_SECONDS=45
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EMBEDDING_MODEL=nomic-embed-text-v1_5
ENRICHMENT_TIMEOUT_SECONDS=12
TAVILY_API_KEY=YOUR_TAVILY_API_KEY
TAVILY_BASE_URL=https://api.tavily.com
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_INDEX_NAME=evolv-developers
PINECONE_REGION=us-east-1
