PROJECT_NAME="Evolv API"
ENVIRONMENT=local
DEBUG=true
API_V1_STR=/api/v1

# Local development uses SQLite by default.
# For production, use a Postgres URL such as:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/evolv
DATABASE_URL=sqlite:///./evolv.db

# Supabase Auth.
# Keep these backend-only. Never expose the service role key in frontend code.
SUPABASE_URL=https://rwhyjahpxivjchowalsc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_AUTH_EMAIL_CONFIRM=true

# Firebase Admin service account JSON, pasted as a single-line JSON string.
# Used only by the backend to verify Firebase phone-auth ID tokens.
FIREBASE_CREDENTIALS_JSON=

SIGNUP_OTP_EXPIRE_MINUTES=5
SIGNUP_OTP_RETURN_DEBUG=false

# Signup OTP email delivery.
# Gmail testing setup:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USERNAME=your-gmail@gmail.com
# SMTP_PASSWORD=your-google-app-password
# EMAIL_FROM_EMAIL=your-gmail@gmail.com
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME="Evolv AI"
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=20

# Replace this before using real authentication or production data.
SECRET_KEY=change-me-in-local-development
ACCESS_TOKEN_EXPIRE_MINUTES=60

# JSON list or comma-separated list are both supported.
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
